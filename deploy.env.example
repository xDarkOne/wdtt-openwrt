# WDTT deployment secrets — copy to deploy.env and fill in.
# deploy.env is gitignored, so your data never lands in the repo.
#
# Use it either by sourcing before the installer:
#     . ./deploy.env && sh scripts/install.sh --slot 0
# or by exporting these as the env in the one-line install.

# Server host or IP (the wdtt-server / wdtt-linkd VPS).
WDTT_SERVER=your-server-ip

# linkd access token (from server/setup-linkd.sh output).
WDTT_TOKEN=your-linkd-token

# Owner password (must match wdtt-server -password).
WDTT_PASSWORD=owner-password

# --- Optional overrides (defaults are usually fine) ---
# WDTT_PORT=56000          # DTLS port on the server
# WDTT_LINKD_PORT=56090    # linkd HTTP port
# WDTT_N=4                 # VK calls per router (4 = fastest sweet spot)
# WDTT_MODE=selective      # selective | lan-all | full

# Per-router slot keeps calls non-overlapping. Do NOT set it here — pass it on
# the install command instead, one distinct value per router:
#     router #1:  --slot 0
#     router #2:  --slot 1
#     router #3:  --slot 2
