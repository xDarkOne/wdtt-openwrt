#!/bin/sh
# wdtt-genlists — assemble the bypass sources into plain list files, then hand
# them to wdtt-resolve which builds the live nft sets. This needs NO dnsmasq-full
# (domains are resolved by wdtt-resolve, big services covered by CIDR subnets).
#
#   domains  -> /etc/wdtt/domains.list     (wdtt-resolve turns these into IPs)
#   subnets  -> /etc/wdtt/subnets4/6.list  (static destination IPs/CIDRs)
#   full IPs -> /etc/wdtt/fullroute.list   (source IPs fully tunneled)
#   DoH IPs  -> /etc/wdtt/doh4/6.list      (blocked so LAN uses router DNS)
#
# Run wdtt-genlists when the *sources* change (config edit, daily cron);
# wdtt-resolve re-runs more often to refresh the resolved IPs.

WD=/etc/wdtt
AD_BASE="https://raw.githubusercontent.com/itdoginfo/allow-domains/main"
DOH_BASE="https://raw.githubusercontent.com/dibdot/DoH-IP-blocklists/master"
WGIFACE=wgturn

BLOCK_DOH=$(uci -q get wdtt.settings.block_doh 2>/dev/null || echo 0)

DOH4_FALLBACK="1.1.1.1
1.0.0.1
1.1.1.2
1.0.0.2
1.1.1.3
1.0.0.3
8.8.8.8
8.8.4.4
9.9.9.9
9.9.9.10
9.9.9.11
149.112.112.112
149.112.112.10
149.112.112.11
94.140.14.14
94.140.15.15
208.67.222.222
208.67.220.220
45.90.28.0/24
45.90.30.0/24"
DOH6_FALLBACK="2606:4700:4700::1111
2606:4700:4700::1001
2001:4860:4860::8888
2001:4860:4860::8844
2620:fe::fe
2620:fe::9
2a10:50c0::ad1:ff
2a10:50c0::ad2:ff"

_dl() {
	uclient-fetch -qO "$2" "$1" 2>/dev/null || curl -fsSL "$1" -o "$2" 2>/dev/null || wget -qO "$2" "$1" 2>/dev/null
}

# fetch with tunnel fallback (lists_via_tunnel: auto|never|always)
fetch() {
	local mode host r routes rc
	mode=$(uci -q get wdtt.settings.lists_via_tunnel 2>/dev/null || echo auto)
	if [ "$mode" != "always" ]; then
		_dl "$1" "$2" && [ -s "$2" ] && return 0
	fi
	[ "$mode" = "never" ] && return 1
	ip link show "$WGIFACE" >/dev/null 2>&1 || return 1
	host=$(echo "$1" | sed -E 's#^https?://##; s#[:/].*##')
	routes=""
	case "$host" in
		*githubusercontent.com|*github.com) routes="185.199.108.0/22 140.82.112.0/20" ;;
	esac
	for r in $(nslookup "$host" 2>/dev/null | grep -oE '([0-9]{1,3}\.){3}[0-9]{1,3}' | tail -n +2); do
		routes="$routes $r/32"
	done
	for r in $routes; do ip route add "$r" dev "$WGIFACE" 2>/dev/null; done
	_dl "$1" "$2"; rc=$?
	for r in $routes; do ip route del "$r" dev "$WGIFACE" 2>/dev/null; done
	[ "$rc" = 0 ] && [ -s "$2" ]
}

# extract bare domain/first-token per line, skipping comments
tokens() { awk 'NF && $1 !~ /^(#|\/\/)/ {print $1}'; }

# free-form (commas/spaces/newlines, // comments) on stdin -> one token per line
clean_free() {
	sed 's#//.*##; s/\r//g' | tr ',;\t ' '\n\n\n\n' | awk 'NF{print $1}'
}

list_path() {
	case "$1" in
		russia_inside)  echo "Russia/inside-raw.lst" ;;
		russia_outside) echo "Russia/outside-raw.lst" ;;
		ukraine_inside) echo "Ukraine/inside-raw.lst" ;;
		anime|block|geoblock|hodca|news|porn) echo "Categories/$1.lst" ;;
		*)              echo "Services/$1.lst" ;;
	esac
}

mkdir -p "$WD" /etc/nftables.d
tmp=$(mktemp)

# ---------------- domains -> $WD/domains.list ----------------
{
	for id in $(uci -q get wdtt.settings.community_list); do
		fetch "$AD_BASE/$(list_path "$id")" "$tmp" && tokens < "$tmp"
	done
	if [ "$(uci -q get wdtt.settings.use_zapret || echo 0)" = 1 ] && [ -f /opt/zapret/ipset/zapret-hosts-user.txt ]; then
		tokens < /opt/zapret/ipset/zapret-hosts-user.txt
	fi
	uci -q get wdtt.settings.custom_domains | clean_free
	for f in $(uci -q get wdtt.settings.local_domain_list); do
		[ -f "$f" ] && tokens < "$f"
	done
	for u in $(uci -q get wdtt.settings.remote_domain_list); do
		fetch "$u" "$tmp" && tokens < "$tmp"
	done
} | sort -u > "$WD/domains.list"

# ---------------- subnets (split by family) ----------------
collect_subnets() {
	uci -q get wdtt.settings.custom_subnets | clean_free
	for f in $(uci -q get wdtt.settings.local_subnet_list); do
		[ -f "$f" ] && tokens < "$f"
	done
	for u in $(uci -q get wdtt.settings.remote_subnet_list); do
		fetch "$u" "$tmp" && tokens < "$tmp"
	done
}
SUBS=$(collect_subnets)
printf '%s\n' "$SUBS" | grep -E '^[0-9]+\.' | sort -u > "$WD/subnets4.list"
printf '%s\n' "$SUBS" | grep ':'            | sort -u > "$WD/subnets6.list"

# ---------------- fully-routed source IPs ----------------
uci -q get wdtt.settings.fully_routed_ip | tr ' ' '\n' | grep -E '^[0-9]' | sort -u > "$WD/fullroute.list"

# ---------------- DoH server IPs ----------------
: > "$WD/doh4.list"; : > "$WD/doh6.list"
if [ "$BLOCK_DOH" = 1 ]; then
	printf '%s\n' "$DOH4_FALLBACK" > "$WD/doh4.list"
	if fetch "$DOH_BASE/doh-ipv4.txt" "$tmp"; then
		awk 'NF && $1 ~ /^[0-9]+\.[0-9]/ {print $1}' "$tmp" | sort -u > "$WD/doh4.list"
	fi
	printf '%s\n' "$DOH6_FALLBACK" > "$WD/doh6.list"
	if fetch "$DOH_BASE/doh-ipv6.txt" "$tmp"; then
		awk 'NF && $1 ~ /:/ {print $1}' "$tmp" | sort -u > "$WD/doh6.list"
	fi
fi

rm -f "$tmp"

# Legacy cleanup: drop the old dnsmasq nftset config if a previous version left it.
rm -f /etc/dnsmasq.d/wdtt-domains.conf /etc/nftables.d/11-wdtt-elements.nft 2>/dev/null

# Build the live nft sets from the lists (resolves domains, no dnsmasq needed).
[ -x /usr/sbin/wdtt-resolve ] && /usr/sbin/wdtt-resolve
exit 0
