#!/bin/sh
# wdtt-genlists — assemble the bypass sets from every configured source.
#
#   domains  -> /etc/dnsmasq.d/wdtt-domains.conf  (dnsmasq fills nft sets on resolve)
#   subnets  -> nft set wdtt_dst4                  (static destination IPs/CIDRs)
#   full IPs -> nft set wdtt_src4                  (source IPs fully tunneled)
#   DoH IPs  -> nft sets wdtt_doh4/6               (blocked so LAN uses router DNS)
#
# block_ipv6=1 also emits AAAA into wdtt_dst6 (nft drops v6 -> clients use v4).
# Static elements live in an /etc/nftables.d include so they survive fw4 reloads.
# Returns 2 if dnsmasq lacks nftset support (nothing is changed then).

NFSET=wdtt_dst4
NFSET6=wdtt_dst6
NFSRC=wdtt_src4
DNSMASQ_DST=/etc/dnsmasq.d/wdtt-domains.conf
SETS_DST=/etc/nftables.d/05-wdtt-sets.nft
AD_BASE="https://raw.githubusercontent.com/itdoginfo/allow-domains/main"
DOH_BASE="https://raw.githubusercontent.com/dibdot/DoH-IP-blocklists/master"
WGIFACE=wgturn

BLOCK_IPV6=$(uci -q get wdtt.settings.block_ipv6 2>/dev/null || echo 0)
BLOCK_DOH=$(uci -q get wdtt.settings.block_doh 2>/dev/null || echo 0)

DOH4_FALLBACK="1.1.1.1,1.0.0.1,1.1.1.2,1.0.0.2,1.1.1.3,1.0.0.3,8.8.8.8,8.8.4.4,9.9.9.9,9.9.9.10,9.9.9.11,149.112.112.112,149.112.112.10,149.112.112.11,94.140.14.14,94.140.15.15,208.67.222.222,208.67.220.220,45.90.28.0/24,45.90.30.0/24"
DOH6_FALLBACK="2606:4700:4700::1111,2606:4700:4700::1001,2001:4860:4860::8888,2001:4860:4860::8844,2620:fe::fe,2620:fe::9,2a10:50c0::ad1:ff,2a10:50c0::ad2:ff"

# join stdin lines with commas (busybox has no `paste`)
join_comma() { tr '\n' ',' | sed 's/,$//'; }

_dl() {
	uclient-fetch -qO "$2" "$1" 2>/dev/null || curl -fsSL "$1" -o "$2" 2>/dev/null || wget -qO "$2" "$1" 2>/dev/null
}

# fetch with tunnel fallback (lists_via_tunnel: auto|never|always)
fetch() {
	local mode host r routes rc
	mode=$(uci -q get wdtt.settings.lists_via_tunnel 2>/dev/null || echo auto)
	if [ "$mode" != "always" ]; then
		_dl "$1" "$2" && [ -s "$2" ] && return 0
	fi
	[ "$mode" = "never" ] && return 1
	ip link show "$WGIFACE" >/dev/null 2>&1 || return 1
	host=$(echo "$1" | sed -E 's#^https?://##; s#[:/].*##')
	routes=""
	case "$host" in
		*githubusercontent.com|*github.com) routes="185.199.108.0/22 140.82.112.0/20" ;;
	esac
	for r in $(nslookup "$host" 2>/dev/null | grep -oE '([0-9]{1,3}\.){3}[0-9]{1,3}' | tail -n +2); do
		routes="$routes $r/32"
	done
	for r in $routes; do ip route add "$r" dev "$WGIFACE" 2>/dev/null; done
	_dl "$1" "$2"; rc=$?
	for r in $routes; do ip route del "$r" dev "$WGIFACE" 2>/dev/null; done
	[ "$rc" = 0 ] && [ -s "$2" ]
}

# domain tokens on stdin -> dnsmasq nftset lines (v4 always, v6 if enabled)
emit() {
	awk -v S4="$NFSET" -v S6="$NFSET6" -v V6="$BLOCK_IPV6" '
		NF && $1 !~ /^(#|\/\/)/ {
			printf "nftset=/%s/4#inet#fw4#%s\n", $1, S4
			if (V6 == "1") printf "nftset=/%s/6#inet#fw4#%s\n", $1, S6
		}'
}

# free-form (commas/spaces/newlines, // comments) on stdin -> one token per line
clean_free() {
	sed 's#//.*##; s/\r//g' | tr ',;\t ' '\n\n\n\n' | awk 'NF{print $1}'
}

list_path() {
	case "$1" in
		russia_inside)  echo "Russia/inside-raw.lst" ;;
		russia_outside) echo "Russia/outside-raw.lst" ;;
		ukraine_inside) echo "Ukraine/inside-raw.lst" ;;
		anime|block|geoblock|hodca|news|porn) echo "Categories/$1.lst" ;;
		*)              echo "Services/$1.lst" ;;
	esac
}

dnsmasq --version 2>/dev/null | grep -q 'no-nftset' && { echo "no-nftset" >&2; exit 2; }

mkdir -p /etc/dnsmasq.d /etc/nftables.d
tmp=$(mktemp)

# ---------------- domains -> dnsmasq nftset ----------------
{
	for id in $(uci -q get wdtt.settings.community_list); do
		fetch "$AD_BASE/$(list_path "$id")" "$tmp" && emit < "$tmp"
	done
	if [ "$(uci -q get wdtt.settings.use_zapret || echo 0)" = 1 ] && [ -f /opt/zapret/ipset/zapret-hosts-user.txt ]; then
		emit < /opt/zapret/ipset/zapret-hosts-user.txt
	fi
	uci -q get wdtt.settings.custom_domains | clean_free | emit
	for f in $(uci -q get wdtt.settings.local_domain_list); do
		[ -f "$f" ] && emit < "$f"
	done
	for u in $(uci -q get wdtt.settings.remote_domain_list); do
		fetch "$u" "$tmp" && emit < "$tmp"
	done
} > "$DNSMASQ_DST"

# ---------------- subnets / fully-routed / DoH -> nft elements ----------------
collect_subnets() {
	uci -q get wdtt.settings.custom_subnets | clean_free
	for f in $(uci -q get wdtt.settings.local_subnet_list); do
		[ -f "$f" ] && awk 'NF && $1 !~ /^(#|\/\/)/ {print $1}' "$f"
	done
	for u in $(uci -q get wdtt.settings.remote_subnet_list); do
		fetch "$u" "$tmp" && awk 'NF && $1 !~ /^(#|\/\/)/ {print $1}' "$tmp"
	done
}

SUBS=$(collect_subnets | grep -E '^[0-9]' | sort -u | join_comma)
FR=$(uci -q get wdtt.settings.fully_routed_ip | tr ' ' '\n' | grep -E '^[0-9]' | sort -u | join_comma)
DOH4=""; DOH6=""
if [ "$BLOCK_DOH" = 1 ]; then
	# dibdot format is "<ip>   # comment" — take the first field with awk
	# (busybox `grep -o` is unreliable, so avoid it).
	DOH4="$DOH4_FALLBACK"
	if fetch "$DOH_BASE/doh-ipv4.txt" "$tmp"; then
		d=$(awk 'NF && $1 ~ /^[0-9]+\.[0-9]/ {print $1}' "$tmp" | sort -u | join_comma)
		[ -n "$d" ] && DOH4="$d"
	fi
	DOH6="$DOH6_FALLBACK"
	if fetch "$DOH_BASE/doh-ipv6.txt" "$tmp"; then
		d=$(awk 'NF && $1 ~ /:/ {print $1}' "$tmp" | sort -u | join_comma)
		[ -n "$d" ] && DOH6="$d"
	fi
fi

# Inline-element set definitions (survive fw4 reloads). dst4/dst6 are also
# filled by dnsmasq at runtime as bypass domains resolve.
emit_set() {  # name family-type elements
	printf 'set %s { type %s; flags interval; auto-merge;' "$1" "$2"
	[ -n "$3" ] && printf ' elements = { %s };' "$3"
	printf ' }\n'
}
{
	emit_set "$NFSET"    ipv4_addr "$SUBS"
	emit_set "$NFSET6"   ipv6_addr ""
	emit_set "$NFSRC"    ipv4_addr "$FR"
	emit_set wdtt_doh4   ipv4_addr "$DOH4"
	emit_set wdtt_doh6   ipv6_addr "$DOH6"
} > "$SETS_DST"
rm -f /etc/nftables.d/11-wdtt-elements.nft 2>/dev/null

rm -f "$tmp"
/etc/init.d/dnsmasq restart >/dev/null 2>&1
fw4 reload >/dev/null 2>&1
exit 0
